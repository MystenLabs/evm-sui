# Copy this file to web/.env.local and fill in the blanks.
# .env.local is git-ignored — do NOT commit secrets.

# ─── EVM side ────────────────────────────────────────────────────────────────

# Address of the deployed EvmWalNFT contract on Anvil. After running
# `pnpm deploy:local`, copy the value from <repo-root>/.deployed-address.
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Walrus upload mode ──────────────────────────────────────────────────────

# Where mint uploads go:
#   - 'backend'   → POST to /api/walrus/upload (this app's local API route,
#                   uses the SUI_PRIVATE_KEY below to sign on Sui and pay WAL)
#   - 'publisher' → direct browser PUT to NEXT_PUBLIC_WALRUS_PUBLISHER_URL
#                   (no Sui keypair needed; the public publisher pays WAL)
# Default if unset: 'backend'.
NEXT_PUBLIC_WALRUS_UPLOAD_MODE=backend

# Optional override of the Walrus testnet public publisher (only used when
# NEXT_PUBLIC_WALRUS_UPLOAD_MODE=publisher).
# NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# ─── Server-side Walrus (only needed when MODE=backend) ──────────────────────
#
# ⚠️  These secrets are read by the /api/walrus/upload route. That route has
# no auth and signs Sui transactions on every call — keep it local-only.
#
# Bech32-encoded Sui keypair, e.g. exported from `sui client export`. Must be
# an ED25519 key. The wallet needs testnet SUI (gas) AND testnet WAL (storage):
#   - Sui  faucet: https://faucet.sui.io/
#   - WAL  faucet: https://docs.wal.app/usage/setup.html#testnet-wal-from-the-faucet
SUI_PRIVATE_KEY=suiprivkey1...

# Sui fullnode gRPC endpoint. Default: https://fullnode.testnet.sui.io:443
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Walrus network — 'testnet' (default) or 'mainnet'. Picks the matching
# SUI_RPC_URL default when SUI_RPC_URL is unset.
# WALRUS_NETWORK=testnet

# Mirror of WALRUS_NETWORK exposed to the browser so the Mint UI links to
# the matching Suiscan explorer (testnet vs mainnet). Keep these two values
# in sync.
# NEXT_PUBLIC_WALRUS_NETWORK=testnet
